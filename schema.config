{
  "app": {
    "name": "Collaboration Tools",
    "description": "Collaboration tools with kanban and knowledge graph",
    "theme_color": "#2563eb",
    "logo_url": null
  },

  "entity_types": [
    {
      "key": "workspace",
      "label": "Workspace",
      "plural": "Workspaces",
      "icon": "business",
      "color": "#6b7280",
      "hidden": false,
      "metadata_schema": {
        "type": "object",
        "properties": {
          "description": { "type": "string" }
        }
      },
      "ui_schema": {
        "ui:order": ["description"],
        "properties": {
          "description": {
            "ui:label": "Description",
            "ui:widget": "textarea"
          }
        },
        "card": {
          "title": "name",
          "fields": []
        },
        "detail": {
          "sections": [
            { "label": "Details", "fields": ["description"] }
          ]
        },
        "filters": []
      }
    },
    {
      "key": "project",
      "label": "Project",
      "plural": "Projects",
      "icon": "folder",
      "color": "#3b82f6",
      "hidden": false,
      "metadata_schema": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "enum": ["active", "paused", "completed", "archived"] },
          "deadline": { "type": "string", "format": "date" },
          "description": { "type": "string" }
        }
      },
      "ui_schema": {
        "ui:order": ["status", "deadline", "description"],
        "properties": {
          "status": {
            "ui:label": "Status",
            "ui:widget": "select",
            "ui:colors": {
              "active": "#10b981",
              "paused": "#f59e0b",
              "completed": "#3b82f6",
              "archived": "#d1d5db"
            }
          },
          "deadline": {
            "ui:label": "Deadline",
            "ui:widget": "date"
          },
          "description": {
            "ui:label": "Description",
            "ui:widget": "textarea"
          }
        },
        "card": {
          "title": "name",
          "fields": ["status", "deadline"]
        },
        "detail": {
          "sections": [
            { "label": "Overview", "fields": ["status", "deadline"] },
            { "label": "Details", "fields": ["description"] }
          ]
        },
        "filters": ["status"]
      }
    },
    {
      "key": "sprint",
      "label": "Sprint",
      "plural": "Sprints",
      "icon": "timer",
      "color": "#8b5cf6",
      "hidden": false,
      "metadata_schema": {
        "type": "object",
        "properties": {
          "start_date": { "type": "string", "format": "date" },
          "end_date": { "type": "string", "format": "date" },
          "goal": { "type": "string" },
          "retro": { "type": "string" },
          "status": { "type": "string", "enum": ["planning", "active", "reviewing", "completed"] }
        },
        "required": ["start_date", "end_date"]
      },
      "ui_schema": {
        "ui:order": ["status", "start_date", "end_date", "goal", "retro"],
        "properties": {
          "status": {
            "ui:label": "Status",
            "ui:widget": "select",
            "ui:colors": {
              "planning": "#94a3b8",
              "active": "#10b981",
              "reviewing": "#a78bfa",
              "completed": "#3b82f6"
            }
          },
          "start_date": {
            "ui:label": "Start Date",
            "ui:widget": "date"
          },
          "end_date": {
            "ui:label": "End Date",
            "ui:widget": "date"
          },
          "goal": {
            "ui:label": "Goal",
            "ui:widget": "textarea"
          },
          "retro": {
            "ui:label": "Retrospective",
            "ui:widget": "textarea"
          }
        },
        "card": {
          "title": "name",
          "fields": ["status", "start_date", "end_date"],
          "subtitle": "goal"
        },
        "detail": {
          "sections": [
            { "label": "Status", "fields": ["status"] },
            { "label": "Schedule", "fields": ["start_date", "end_date"] },
            { "label": "Goal", "fields": ["goal"] },
            { "label": "Retrospective", "fields": ["retro"] }
          ]
        },
        "filters": ["status"]
      }
    },
    {
      "key": "task",
      "label": "Task",
      "plural": "Tasks",
      "icon": "check_circle",
      "color": "#10b981",
      "hidden": false,
      "metadata_schema": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "enum": ["backlog", "todo", "in_progress", "review", "done", "archived"] },
          "priority": { "type": "string", "enum": ["low", "medium", "high", "urgent"] },
          "deadline": { "type": "string", "format": "date" },
          "estimate": { "type": "number" },
          "labels": { "type": "array", "items": { "type": "string" } }
        }
      },
      "ui_schema": {
        "ui:order": ["status", "priority", "deadline", "estimate", "labels"],
        "properties": {
          "status": {
            "ui:label": "Status",
            "ui:widget": "select",
            "ui:kanban_column": true,
            "ui:colors": {
              "backlog": "#94a3b8",
              "todo": "#60a5fa",
              "in_progress": "#f59e0b",
              "review": "#a78bfa",
              "done": "#34d399",
              "archived": "#d1d5db"
            }
          },
          "priority": {
            "ui:label": "Priority",
            "ui:widget": "select",
            "ui:colors": {
              "low": "#94a3b8",
              "medium": "#60a5fa",
              "high": "#f59e0b",
              "urgent": "#ef4444"
            }
          },
          "deadline": {
            "ui:label": "Due Date",
            "ui:widget": "date"
          },
          "estimate": {
            "ui:label": "Estimate",
            "ui:widget": "number",
            "ui:suffix": "pts"
          },
          "labels": {
            "ui:label": "Labels",
            "ui:widget": "tags"
          }
        },
        "card": {
          "title": "name",
          "fields": ["priority", "deadline"],
          "subtitle": "@project.name"
        },
        "detail": {
          "sections": [
            { "label": "Workflow", "fields": ["status", "priority"] },
            { "label": "Planning", "fields": ["deadline", "estimate"] },
            { "label": "Tags", "fields": ["labels"] }
          ]
        },
        "filters": ["status", "priority", "labels"]
      }
    },
    {
      "key": "document",
      "label": "Document",
      "plural": "Documents",
      "icon": "description",
      "color": "#f59e0b",
      "hidden": false,
      "metadata_schema": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "enum": ["active", "archived"] },
          "doc_type": { "type": "string", "enum": ["spec", "note", "report", "reference"] },
          "url": { "type": "string", "format": "uri" },
          "labels": { "type": "array", "items": { "type": "string" } }
        }
      },
      "ui_schema": {
        "ui:order": ["status", "doc_type", "url", "labels"],
        "properties": {
          "status": {
            "ui:label": "Status",
            "ui:widget": "select",
            "ui:colors": {
              "active": "#10b981",
              "archived": "#d1d5db"
            }
          },
          "doc_type": {
            "ui:label": "Type",
            "ui:widget": "select",
            "ui:colors": {
              "spec": "#3b82f6",
              "note": "#10b981",
              "report": "#f59e0b",
              "reference": "#8b5cf6"
            }
          },
          "url": {
            "ui:label": "URL",
            "ui:widget": "url"
          },
          "labels": {
            "ui:label": "Labels",
            "ui:widget": "tags"
          }
        },
        "card": {
          "title": "name",
          "fields": ["doc_type", "status"],
          "subtitle": "@task.name"
        },
        "detail": {
          "sections": [
            { "label": "Status", "fields": ["status"] },
            { "label": "Classification", "fields": ["doc_type"] },
            { "label": "Link", "fields": ["url"] },
            { "label": "Tags", "fields": ["labels"] }
          ]
        },
        "filters": ["status", "doc_type", "labels"]
      }
    },
    {
      "key": "person",
      "label": "Person",
      "plural": "People",
      "icon": "person",
      "color": "#ec4899",
      "hidden": false,
      "metadata_schema": {
        "type": "object",
        "properties": {
          "email": { "type": "string", "format": "email" },
          "role": { "type": "string" }
        }
      },
      "ui_schema": {
        "ui:order": ["role", "email"],
        "properties": {
          "email": {
            "ui:label": "Email",
            "ui:widget": "email"
          },
          "role": {
            "ui:label": "Role",
            "ui:widget": "text"
          }
        },
        "card": {
          "title": "name",
          "fields": ["role"],
          "subtitle": "email"
        },
        "detail": {
          "sections": [
            { "label": "Info", "fields": ["role", "email"] }
          ]
        },
        "filters": []
      }
    }
  ],

  "rel_types": [
    {
      "key": "contains_project",
      "forward_label": "contains",
      "reverse_label": "belongs to",
      "source_types": ["workspace"],
      "target_types": ["project"],
      "symmetric": false
    },
    {
      "key": "contains_task",
      "forward_label": "contains",
      "reverse_label": "project",
      "source_types": ["workspace", "project"],
      "target_types": ["task"],
      "symmetric": false
    },
    {
      "key": "contains_doc",
      "forward_label": "has document",
      "reverse_label": "attached to",
      "source_types": ["task"],
      "target_types": ["document"],
      "symmetric": false
    },
    {
      "key": "contains_sprint",
      "forward_label": "contains",
      "reverse_label": "belongs to",
      "source_types": ["workspace", "project"],
      "target_types": ["sprint"],
      "symmetric": false
    },
    {
      "key": "owned_by",
      "forward_label": "owned by",
      "reverse_label": "has sprint",
      "source_types": ["sprint"],
      "target_types": ["person"],
      "symmetric": false
    },
    {
      "key": "in_sprint",
      "forward_label": "scheduled in",
      "reverse_label": "includes",
      "source_types": ["task"],
      "target_types": ["sprint"],
      "symmetric": false
    },
    {
      "key": "participates_in",
      "forward_label": "participates in",
      "reverse_label": "has participant",
      "source_types": ["person"],
      "target_types": ["sprint"],
      "symmetric": false,
      "metadata_schema": {
        "type": "object",
        "properties": {
          "goal": { "type": "string" },
          "reflection": { "type": "string" }
        }
      }
    },
    {
      "key": "assigned_to",
      "forward_label": "assigned to",
      "reverse_label": "responsible for",
      "source_types": ["task"],
      "target_types": ["person"],
      "symmetric": false
    },
    {
      "key": "authored",
      "forward_label": "authored",
      "reverse_label": "authored by",
      "source_types": ["person"],
      "target_types": ["document"],
      "symmetric": false
    },
    {
      "key": "references",
      "forward_label": "references",
      "reverse_label": "referenced by",
      "source_types": ["task"],
      "target_types": ["document"],
      "symmetric": false
    },
    {
      "key": "depends_on",
      "forward_label": "depends on",
      "reverse_label": "blocks",
      "source_types": ["task"],
      "target_types": ["task"],
      "symmetric": false
    },
    {
      "key": "subtask_of",
      "forward_label": "subtask of",
      "reverse_label": "has subtask",
      "source_types": ["task"],
      "target_types": ["task"],
      "symmetric": false
    },
    {
      "key": "collaborates",
      "forward_label": "works with",
      "reverse_label": "works with",
      "source_types": ["person"],
      "target_types": ["person"],
      "symmetric": true
    }
  ],

  "permission_rules": [
    { "rule_type": "admin_only_entity_type", "entity_type_key": "workspace" },
    { "rule_type": "admin_only_entity_type", "entity_type_key": "person" },
    { "rule_type": "edit_granting_rel_type", "rel_type_key": "assigned_to" },
    { "rule_type": "edit_granting_rel_type", "rel_type_key": "authored" }
  ],

  "auto_relationships": [
    {
      "trigger": "create",
      "entity_type": "sprint",
      "rel_type_key": "owned_by",
      "target": "current_user"
    },
    {
      "trigger": "create",
      "entity_type": "sprint",
      "rel_type_key": "participates_in",
      "target": "current_user"
    },
    {
      "trigger": "create",
      "entity_type": "document",
      "rel_type_key": "authored",
      "target": "current_user"
    }
  ],

  "seed_data": {
    "entities": [],
    "relationships": []
  }
}
