{
  "app": {
    "name": "Outlier",
    "description": "Accountability tracker with kanban and knowledge graph",
    "theme_color": "#2563eb",
    "logo_url": null
  },

  "entity_types": [
    {
      "key": "workspace",
      "label": "Workspace",
      "plural": "Workspaces",
      "icon": "business",
      "color": "#6b7280",
      "hidden": false,
      "metadata_schema": {
        "type": "object",
        "properties": {
          "description": { "type": "string" }
        }
      }
    },
    {
      "key": "project",
      "label": "Project",
      "plural": "Projects",
      "icon": "folder",
      "color": "#3b82f6",
      "hidden": false,
      "metadata_schema": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "enum": ["active", "paused", "completed", "archived"] },
          "deadline": { "type": "string", "format": "date" },
          "description": { "type": "string" }
        }
      }
    },
    {
      "key": "sprint",
      "label": "Sprint",
      "plural": "Sprints",
      "icon": "timer",
      "color": "#8b5cf6",
      "hidden": false,
      "metadata_schema": {
        "type": "object",
        "properties": {
          "start_date": { "type": "string", "format": "date" },
          "end_date": { "type": "string", "format": "date" },
          "goal": { "type": "string" }
        },
        "required": ["start_date", "end_date"]
      }
    },
    {
      "key": "task",
      "label": "Task",
      "plural": "Tasks",
      "icon": "check_circle",
      "color": "#10b981",
      "hidden": false,
      "metadata_schema": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "enum": ["backlog", "todo", "in_progress", "review", "done", "archived"] },
          "priority": { "type": "string", "enum": ["low", "medium", "high", "urgent"] },
          "deadline": { "type": "string", "format": "date" },
          "estimate": { "type": "number" },
          "labels": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    {
      "key": "document",
      "label": "Document",
      "plural": "Documents",
      "icon": "description",
      "color": "#f59e0b",
      "hidden": false,
      "metadata_schema": {
        "type": "object",
        "properties": {
          "doc_type": { "type": "string", "enum": ["spec", "note", "report", "reference"] },
          "url": { "type": "string", "format": "uri" },
          "labels": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    {
      "key": "person",
      "label": "Person",
      "plural": "People",
      "icon": "person",
      "color": "#ec4899",
      "hidden": false,
      "metadata_schema": {
        "type": "object",
        "properties": {
          "email": { "type": "string", "format": "email" },
          "role": { "type": "string" }
        }
      }
    }
  ],

  "rel_types": [
    {
      "key": "contains_project",
      "forward_label": "contains",
      "reverse_label": "belongs to",
      "source_types": ["workspace"],
      "target_types": ["project"],
      "symmetric": false
    },
    {
      "key": "contains_task",
      "forward_label": "contains",
      "reverse_label": "belongs to",
      "source_types": ["project"],
      "target_types": ["task"],
      "symmetric": false
    },
    {
      "key": "contains_doc",
      "forward_label": "contains",
      "reverse_label": "belongs to",
      "source_types": ["project"],
      "target_types": ["document"],
      "symmetric": false
    },
    {
      "key": "owned_by",
      "forward_label": "owned by",
      "reverse_label": "has sprint",
      "source_types": ["sprint"],
      "target_types": ["person"],
      "symmetric": false
    },
    {
      "key": "in_sprint",
      "forward_label": "scheduled in",
      "reverse_label": "includes",
      "source_types": ["task"],
      "target_types": ["sprint"],
      "symmetric": false
    },
    {
      "key": "assigned_to",
      "forward_label": "assigned to",
      "reverse_label": "responsible for",
      "source_types": ["task"],
      "target_types": ["person"],
      "symmetric": false
    },
    {
      "key": "authored",
      "forward_label": "authored",
      "reverse_label": "authored by",
      "source_types": ["person"],
      "target_types": ["document"],
      "symmetric": false
    },
    {
      "key": "references",
      "forward_label": "references",
      "reverse_label": "referenced by",
      "source_types": ["task"],
      "target_types": ["document"],
      "symmetric": false
    },
    {
      "key": "depends_on",
      "forward_label": "depends on",
      "reverse_label": "blocks",
      "source_types": ["task"],
      "target_types": ["task"],
      "symmetric": false
    },
    {
      "key": "subtask_of",
      "forward_label": "subtask of",
      "reverse_label": "has subtask",
      "source_types": ["task"],
      "target_types": ["task"],
      "symmetric": false
    },
    {
      "key": "collaborates",
      "forward_label": "works with",
      "reverse_label": "works with",
      "source_types": ["person"],
      "target_types": ["person"],
      "symmetric": true
    }
  ],

  "permission_rules": [
    { "rule_type": "admin_only_entity_type", "entity_type_key": "workspace" },
    { "rule_type": "admin_only_entity_type", "entity_type_key": "person" },
    { "rule_type": "edit_granting_rel_type", "rel_type_key": "assigned_to" },
    { "rule_type": "edit_granting_rel_type", "rel_type_key": "authored" }
  ],

  "auto_relationships": [
    {
      "trigger": "create",
      "entity_type": "sprint",
      "rel_type_key": "owned_by",
      "target": "current_user"
    }
  ],

  "seed_data": {
    "entities": [],
    "relationships": []
  }
}
